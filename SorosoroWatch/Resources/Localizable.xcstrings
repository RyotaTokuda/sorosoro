    "paywall.legal" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Subscriptions are charged after confirmation. They auto-renew unless canceled 24 hours before the current period ends. Manage in App Store → Settings → Apple ID → Subscriptions." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "サブスクリプションは確認後に課金されます。現在の期間終了24時間前までにキャンセルしない限り自動更新されます。App Store「設定」→「Apple ID」→「サブスクリプション」から解約できます。" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "确认后将收取订阅费用。除非在当前期限结束前24小时取消，否则将自动续订。可在App Store「设置」→「Apple ID」→「订阅」中取消。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "確認後將收取訂閱費用。除非在當前期限結束前24小時取消，否則將自動續訂。可在App Store「設定」→「Apple ID」→「訂閱」中取消。" } }
      }
